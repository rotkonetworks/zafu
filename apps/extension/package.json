{
  "name": "zafu",
  "version": "0.1.0",
  "private": true,
  "license": "(MIT OR Apache-2.0)",
  "description": "multi-chain privacy wallet for penumbra, zcash, and more",
  "type": "module",
  "scripts": {
    "build": "pnpm bundle:prod && pnpm bundle:beta",
    "bundle:beta": "NODE_OPTIONS=\"--max-old-space-size=8192 --import=tsx\" webpack --config webpack.beta-config.ts",
    "bundle:prod": "NODE_OPTIONS=\"--max-old-space-size=8192 --import=tsx\" webpack --config webpack.prod-config.ts",
    "clean": "rm -rfv dist beta-dist bin",
    "dev": "NODE_ENV=testnet pnpm bundle:beta --watch --mode=development -d inline-source-map",
    "lint": "eslint src",
    "lint:strict": "tsc --noEmit && eslint src --max-warnings 0",
    "test": "vitest run"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^1.10.0",
    "@connectrpc/connect": "^1.6.1",
    "@connectrpc/connect-web": "^1.6.1",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@penumbra-labs/registry": "^12.8.0",
    "@penumbra-zone/bech32m": "18.0.0",
    "@penumbra-zone/client": "29.0.0",
    "@penumbra-zone/getters": "28.0.0",
    "@penumbra-zone/keys": "4.2.3",
    "@penumbra-zone/perspective": "61.1.1",
    "@penumbra-zone/protobuf": "11.0.0",
    "@penumbra-zone/query": "workspace:*",
    "@penumbra-zone/storage": "62.0.0",
    "@penumbra-zone/transport-chrome": "9.0.1",
    "@penumbra-zone/transport-dom": "7.5.2",
    "@radix-ui/react-icons": "^1.3.2",
    "@repo/context": "workspace:*",
    "@repo/custody-chrome": "workspace:*",
    "@repo/encryption": "workspace:*",
    "@repo/storage-chrome": "workspace:*",
    "@repo/ui": "workspace:*",
    "@repo/wallet": "workspace:*",
    "@repo/zcash-wasm": "workspace:*",
    "@rotko/penumbra-services": "70.0.0",
    "@rotko/penumbra-types": "37.0.0",
    "@rotko/penumbra-wasm": "55.0.1",
    "@tanstack/react-query": "5.95.2",
    "exponential-backoff": "^3.1.3",
    "framer-motion": "^12.38.0",
    "html5-qrcode": "^2.3.8",
    "immer": "^11.1.4",
    "lodash": "^4.17.23",
    "lucide-react": "^0.439.0",
    "qrcode": "^1.5.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-loader-spinner": "^6.1.6",
    "react-router-dom": "^6.30.3",
    "solid-js": "^1.9.12",
    "usehooks-ts": "^3.1.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-typescript": "^7.28.5",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/chrome": "0.0.270",
    "@types/firefox-webext-browser": "^143.0.0",
    "@types/lodash": "^4.17.24",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/webpack": "^5.28.5",
    "babel-loader": "^10.1.1",
    "babel-preset-solid": "^1.9.12",
    "bip39": "^3.1.0",
    "buffer": "^6.0.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.2",
    "html-webpack-plugin": "^5.6.6",
    "postcss": "^8.5.8",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.1.8",
    "ts-loader": "^9.5.4",
    "tsx": "^4.21.0",
    "web-ext": "^8.10.0",
    "webpack": "^5.105.4",
    "webpack-cli": "^5.1.4",
    "webpack-merge": "^6.0.1",
    "webpack-watch-external-files-plugin": "^3.1.0"
  }
}
